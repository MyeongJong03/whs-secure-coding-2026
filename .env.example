# Copy to .env and replace this placeholder with a random Secret Key.
# The application will not start while this placeholder is unchanged.
# The replacement must be a random value with at least 32 characters.
SECRET_KEY=replace-with-a-long-random-local-value
FLASK_CONFIG=development
FLASK_DEBUG=0
HOST=127.0.0.1
PORT=5000
# DATABASE_URL=sqlite:////absolute/path/to/local.db
